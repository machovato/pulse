// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// LOCAL DEV: provider = "sqlite"  + DATABASE_URL="file:./dev.db"
// RAILWAY:   Change provider to "postgresql" and set DATABASE_URL to the Railway connection string.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Update {
  id             String   @id @default(cuid())
  title          String
  date           DateTime
  template       String
  rag            String?
  status         String   @default("Draft")
  content_json   String
  source_raw     String
  schema_version Int      @default(1)
  pinned         Boolean  @default(false)
  archived       Boolean  @default(false)
  created_at     DateTime @default(now())
}

model Post {
  id              String   @id @default(cuid())
  project         String
  pillar          String
  theme           String
  hook            String
  body            String
  cta             String?
  hashtags        String   @default("[]")
  hook_char_count Int
  total_char_count Int
  voice_version   String   @default("1.0")
  content_json    String
  source_raw      String
  platform        String   @default("LinkedIn")
  status          String   @default("Draft")
  archived        Boolean  @default(false)
  created_at      DateTime @default(now())
}
